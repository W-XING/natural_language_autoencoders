+    def gen_multi_turn_loss_mask_harmony(
+        self, messages: list[dict], tools: list[dict] = None
+    ) -> tuple[list[int], list[int]]:
+        """Harmony (gpt-oss) forced_final split — NLA patch 0003.
+
+        The generic path can't serve Harmony: the template renders assistant
+        content as <|start|>assistant<|channel|>final<|message|>{content}
+        <|return|>, so _turn_close_ids' "full = head + body + close"
+        assumption breaks on the channel header. Layout here:
+
+          prompt   = chat-template head (ends <|start|>assistant)
+                     + <|channel|>final<|message|>   ← MASKED. Rollouts
+                       prefill these tokens (NLA forced_final mode), so the
+                       model never generates them and must not be supervised
+                       on them.
+          response = content tokens + <|return|>     ← supervised; <|return|>
+                       teaches the model to close the turn.
+
+        Single-user-turn only, like generic. The prompt side MUST equal the
+        rollout prompt nla_generate builds (head + same prefix) — divergence
+        means SFT and RL train on different prompt token streams.
+        """
+        prompt = self.tokenizer.apply_chat_template(
+            messages[:1], tokenize=False, add_generation_prompt=True, tools=tools
+        )
+        response = messages[-1]["content"]
+        prefix_ids, close_ids = self._harmony_affixes()
+        prompt_tokens = self.tokenizer(prompt, add_special_tokens=False)["input_ids"] + prefix_ids
+        response_tokens = self.tokenizer(response, add_special_tokens=False)["input_ids"] + close_ids
+
+        token_ids = prompt_tokens + response_tokens
+        loss_mask = [0] * len(prompt_tokens) + [1] * len(response_tokens)
+
+        if messages[-1].get("step_loss_mask", 1) != 1:
+            loss_mask = [0] * len(token_ids)
+        return token_ids, loss_mask
+
