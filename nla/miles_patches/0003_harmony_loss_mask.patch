+    def _harmony_affixes(self) -> tuple[list[int], list[int]]:
+        """(final_prefix_ids, close_ids) the Harmony template wraps around
+        assistant content. gpt-oss: <|channel|>final<|message|> = [200005,
+        17196, 200008] and <|return|> = [200002] — resolved from the LIVE
+        tokenizer, never hardcoded. Same probe as _turn_close_ids, but instead
+        of asserting body follows head directly, locate body and split the
+        remainder into prefix (between head and body) and close (after body).
+        Mirrors nla.schema.compute_harmony_affixes — keep the two in sync.
+        """
+        if self._cached_harmony_affixes is not None:
+            return self._cached_harmony_affixes
+        probe = [{"role": "user", "content": "x"}, {"role": "assistant", "content": "y"}]
+        full = self.tokenizer.apply_chat_template(probe, tokenize=True, add_generation_prompt=False)
+        head = self.tokenizer.apply_chat_template(probe[:1], tokenize=True, add_generation_prompt=True)
+        body = self.tokenizer("y", add_special_tokens=False)["input_ids"]
+        lcp = 0
+        while lcp < min(len(full), len(head)) and full[lcp] == head[lcp]:
+            lcp += 1
+        starts = [
+            i for i in range(lcp, len(full) - len(body) + 1)
+            if full[i:i + len(body)] == body
+        ]
+        assert len(starts) == 1, (
+            f"cannot isolate assistant body in Harmony probe render: "
+            f"full={full} head={head} body={body} lcp={lcp} starts={starts}"
+        )
+        prefix, close = full[lcp:starts[0]], full[starts[0] + len(body):]
+        assert prefix, (
+            f"no tokens between generation prompt and assistant content — "
+            f"single-channel template, use tokenizer_type='generic' instead. "
+            f"full={full} head={head}"
+        )
+        assert close, f"no close token after assistant content: full={full}"
+        self._cached_harmony_affixes = (prefix, close)
+        return self._cached_harmony_affixes
+
